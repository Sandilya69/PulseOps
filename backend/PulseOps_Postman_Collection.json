{
  "info": {
    "name": "PulseOps CRM Backend",
    "description": "API Collection for the PulseOps CRM backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "orgId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "2. Auth",
      "item": [
        {
          "name": "Signup",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.success) {",
                  "    pm.collectionVariables.set(\"accessToken\", response.data.tokens.accessToken);",
                  "    pm.collectionVariables.set(\"orgId\", response.data.organization.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Test User\",\n    \"email\": \"test@example.com\",\n    \"password\": \"Password123!\",\n    \"organizationName\": \"Acme Corp\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "signup"
              ]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.success) {",
                  "    pm.collectionVariables.set(\"accessToken\", response.data.tokens.accessToken);",
                  "    pm.collectionVariables.set(\"orgId\", response.data.organization.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"test@example.com\",\n    \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Get Me (Profile)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "3. Organization",
      "item": [
        {
          "name": "Get Current Organization",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/organizations/{{orgId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "organizations",
                "{{orgId}}"
              ]
            }
          }
        },
        {
          "name": "Get Org Stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/organizations/{{orgId}}/stats",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "organizations",
                "{{orgId}}",
                "stats"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "4. CRM & Tickets",
      "item": [
        {
          "name": "Create Ticket",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Login page is loading slowly\",\n    \"description\": \"Whenever I navigate to /login it takes 10 seconds to load.\",\n    \"category\": \"bug\",\n    \"priority\": \"high\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/organizations/{{orgId}}/tickets",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "organizations",
                "{{orgId}}",
                "tickets"
              ]
            }
          }
        },
        {
          "name": "List Tickets",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/organizations/{{orgId}}/tickets",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "organizations",
                "{{orgId}}",
                "tickets"
              ]
            }
          }
        },
        {
          "name": "List Activity Logs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/organizations/{{orgId}}/activity-logs",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "organizations",
                "{{orgId}}",
                "activity-logs"
              ]
            }
          }
        }
      ]
    }
  ]
}
